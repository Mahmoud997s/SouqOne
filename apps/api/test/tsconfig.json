{
  "compilerOptions": {
    "module": "commonjs",
    "target": "es2017",
    "lib": ["es2017"],
    "declaration": false,
    "noEmit": true,
    "strict": false,
    "esModuleInterop": true,
    "moduleResolution": "node",
    "baseUrl": "..",
    "paths": {
      "src/*": ["src/*"]
    },
    "types": ["jest", "node"]
  },
  "include": ["./**/*.ts", "../src/**/*.ts"]
}
